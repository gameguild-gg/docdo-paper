# ============================================================================
# .gitignore — Research Repository
# ============================================================================
# This file prevents accidental commits of:
# - Large data files (use DVC instead)
# - Sensitive/private content
# - Build artifacts and caches
# - Environment-specific files
# ============================================================================

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# PyInstaller
*.manifest
*.spec

# Virtual environments
.env
.env.local
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/

# Testing
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

